generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  NURSE
  DOCTOR
  PLATFORM_ADMIN
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  type      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  email     String   @unique
  password  String
  role      Role
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}
